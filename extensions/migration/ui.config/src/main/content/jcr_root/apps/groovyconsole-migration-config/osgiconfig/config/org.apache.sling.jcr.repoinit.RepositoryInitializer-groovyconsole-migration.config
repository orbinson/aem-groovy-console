scripts=[
"
create path /conf/groovyconsole(sling:Folder)
create path /conf/groovyconsole/scripts(sling:Folder)
create path /conf/groovyconsole/scripts/migration(sling:Folder)
create path /var/groovyconsole(sling:Folder)
create path /var/groovyconsole/migration(sling:Folder)

create service user aem-groovy-console-migration-service with path system/aem-groovy-console
set ACL for aem-groovy-console-migration-service
    # migration scripts perform arbitrary content updates (AECU replacement), so the service user
    # needs full repository access like the console's own service user
    allow jcr:all on /
end
"]
