scripts=[
"
create path /conf/groovyconsole(sling:Folder)
create path /conf/groovyconsole/replication(sling:Folder)
create path /var/groovyconsole/audit(sling:Folder)

create service user aem-groovy-console-service with path system/aem-groovy-console
set ACL for aem-groovy-console-service
    # scheduled jobs and replicated scripts execute arbitrary (admin-authored) Groovy with this service
    # user, so it needs full repository access. Endpoints that expose this resolver enforce the console
    # permission themselves; audit records are additionally guarded per-user (see AuditAccessControl).
    allow jcr:all on /
    allow jcr:all on /var/groovyconsole/audit
end
"]
